# ══════════════════════════════════════════════════════════════════
#  Catatanku — Environment Variables
#  RENAME file ini menjadi .env dan isi nilainya sebelum deploy!
#  JANGAN commit file .env ke Git!
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=catatanku
POSTGRES_USER=catatanku_user
# WAJIB diganti — gunakan password yang kuat!
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MINIMAL_32_KARAKTER

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=GANTI_DENGAN_REDIS_PASSWORD_KUAT

# ── Flask / JWT ──────────────────────────────────────────────────
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_ACAK_64_KARAKTER
JWT_SECRET_KEY=GANTI_DENGAN_JWT_SECRET_ACAK_64_KARAKTER

# ── CORS ─────────────────────────────────────────────────────────
# Domain frontend kamu (pisahkan dengan koma jika lebih dari satu)
ALLOWED_ORIGINS=https://catatanku.example.com
