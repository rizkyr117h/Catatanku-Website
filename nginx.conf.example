# Simpan file ini ke: /etc/nginx/sites-available/catatanku
# Lalu: sudo ln -s /etc/nginx/sites-available/catatanku /etc/nginx/sites-enabled/
# Lalu: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name catatanku.rizkytech.cloud;

    # Setelah dapat SSL dari certbot, jalankan:
    # sudo certbot --nginx -d catatanku.rizkytech.cloud
    # Certbot akan otomatis update file ini untuk HTTPS

    # Frontend (file HTML statis)
    root /var/www/catatanku;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # API → Flask di port 4502
    location /api/ {
        proxy_pass         http://127.0.0.1:4502;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
